# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Git worktrees
.worktrees/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
junit.xml
*.test.js.snap
*.test.ts.snap
*.test.tsx.snap

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!src-go/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

#Windsurf
.windsurfrules
.ace-tool/

# Claude Code skills surface — junctions/symlinks to .agents/skills/.
# The canonical source is .agents/skills/ (tracked); .claude/skills/ is
# regenerated locally by `npx skills experimental_install` plus local re-link.
.claude/skills/

# Go backend binaries (compiled artifacts)
src-tauri/binaries/server*
!src-tauri/binaries/.gitkeep

# Go build cache
src-go/.env
